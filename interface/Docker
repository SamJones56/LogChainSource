# Docker
FROM python:3.10-slim


# Create a working directory
WORKDIR /app

# Copy requirements first (Docker layer caching)
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy app code
COPY app.py .

# Expose Flask port
EXPOSE 5000

# Run the Flask app
CMD ["python", "app.py"]